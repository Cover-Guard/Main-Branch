{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "name": "coverguard-api",
  "version": 2,
  "builds": [
    {
      "src": "src/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/index.ts"
    }
  ],
  "regions": ["iad1"],
  "env": {
    "SUPABASE_URL": "@coverguard-supabase-url",
    "SUPABASE_ANON_KEY": "@coverguard-supabase-anon-key",
    "SUPABASE_SERVICE_ROLE_KEY": "@coverguard-supabase-service-role-key",
    "DATABASE_URL": "@coverguard-database-url",
    "JWT_SECRET": "@coverguard-jwt-secret",
    "CORS_ALLOWED_ORIGINS": "https://coverguard.io,https://www.coverguard.io",
    "ATTOM_API_KEY": "@coverguard-attom-api-key",
    "NODE_ENV": "production"
  }
}
