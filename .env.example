# =============================================================
# CoverGuard — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file.
# =============================================================

# ── Supabase ──────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Pooled connection string for Prisma runtime queries (Supabase pooler, port 6543)
# Found in: Supabase Dashboard → Project Settings → Database → Connection pooling → Transaction mode
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:6543/postgres?pgbouncer=true

# Direct (non-pooled) connection for Prisma migrations (port 5432)
# Found in: Supabase Dashboard → Project Settings → Database → Connection string (URI)
DIRECT_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ── API Server ────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
API_BASE_URL=http://localhost:4000

# JWT signing secret for session tokens (min 32 chars)
JWT_SECRET=change-me-to-a-long-random-string

# CORS: comma-separated allowed origins
# Production: https://coverguard.io,https://www.coverguard.io
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://coverguard.io,https://www.coverguard.io

# ── Next.js / Web App ─────────────────────────────────────────
# Server-only URL used by Next.js rewrite proxy (never sent to browser).
# Local dev:  http://localhost:4000
# Production: https://api.coverguard.io  (or internal VPC address)
API_URL=http://localhost:4000

# NEXT_PUBLIC_API_URL is no longer used by the web app — all API calls go through
# the Next.js rewrite proxy (/api/* → Express). Remove from browser bundles.
# NEXT_PUBLIC_API_URL=http://localhost:4000  # deprecated — use API_URL above
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# ── External Data Integrations ────────────────────────────────
# ATTOM Data Solutions — property data
ATTOM_API_KEY=

# Mapbox — property maps
NEXT_PUBLIC_MAPBOX_TOKEN=

# FEMA / flood data (public API — no key required, but rate-limited)
FEMA_API_BASE_URL=https://hazards.fema.gov/gis/nfhl/rest/services

# CoreLogic / LexisNexis CLUE (insurance history)
CORELOGIC_API_KEY=

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ── Monitoring ────────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=info
